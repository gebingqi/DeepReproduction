# DeepReproduction environment template
# Fill in the values below before running the agents.

# -----------------------------------------------------------------------------
# Knowledge agent
# -----------------------------------------------------------------------------
# Model used by the standalone knowledge stage.
KNOWLEDGE_AGENT_MODEL=deepseek-chat

# API key for the knowledge agent model provider.
KNOWLEDGE_AGENT_API_KEY=

# Optional OpenAI-compatible base URL.
# Leave empty when using the default OpenAI endpoint.
KNOWLEDGE_AGENT_BASE_URL=https://api.deepseek.com


# -----------------------------------------------------------------------------
# Build agent
# -----------------------------------------------------------------------------
BUILD_AGENT_MODEL=deepseek-chat
BUILD_AGENT_API_KEY=
BUILD_AGENT_BASE_URL=


# -----------------------------------------------------------------------------
# PoC agent
# -----------------------------------------------------------------------------
POC_AGENT_MODEL=deepseek-chat
POC_AGENT_API_KEY=
POC_AGENT_BASE_URL=


# -----------------------------------------------------------------------------
# Verify agent
# -----------------------------------------------------------------------------
VERIFY_AGENT_MODEL=deepseek-chat
VERIFY_AGENT_API_KEY=
VERIFY_AGENT_BASE_URL=


# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
# Maximum retry count for the build stage.
MAX_BUILD_RETRY=2

# Maximum retry count for the PoC stage.
MAX_POC_RETRY=2

# Workspace root directory relative to `source/`.
WORKSPACE_ROOT=workspaces

# Maximum recursive URL traversal depth used by the knowledge stage.
KNOWLEDGE_MAX_REFERENCE_DEPTH=3

# Maximum number of fetched references used by the knowledge stage.
KNOWLEDGE_MAX_FETCH_COUNT=12

# Timeout for each remote fetch in the knowledge stage.
KNOWLEDGE_FETCH_TIMEOUT_SECONDS=8

# Whether to enable LLM curation for the knowledge stage.
KNOWLEDGE_ENABLE_LLM_CURATION=1

# Timeout for LLM requests.
LLM_TIMEOUT_SECONDS=30
